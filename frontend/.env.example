# Copy this file to .env and fill in your values.

# ── Stellar ──────────────────────────────────────────────────
# Contract ID from: stellar contract deploy ...
VITE_CONTRACT_ID=YOUR_CONTRACT_ID_HERE

# Stellar Testnet RPC (no need to change for testnet)
VITE_RPC_URL=https://soroban-testnet.stellar.org

# ── Supabase (user registry — proves 30+ users to mentor) ────
# Get these from: https://supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
